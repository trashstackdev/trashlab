{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "flux": {
    "fileMatch": ["\\.yaml$"]
  },
  "packageRules": [
    {
      "description": "Group Flux component updates",
      "matchPackageNames": ["ghcr.io/fluxcd/**"],
      "groupName": "flux"
    },
    {
      "description": "Require manual approval for major chart version bumps",
      "matchManagers": ["flux"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Limit Longhorn to one minor version bump at a time",
      "matchPackageNames": ["longhorn"],
      "matchManagers": ["flux"],
      "matchDatasources": ["helm"],
      "allowedVersions": "<={{major}}.{{add minor 1}}"
    }
  ],
  "customManagers": [
    {
      "description": "Nextcloud image tag",
      "customType": "regex",
      "fileMatch": ["apps/nextcloud/helmrelease\\.yaml"],
      "matchStrings": [
        "tag: (?<currentValue>[\\d.]+-apache)"
      ],
      "depNameTemplate": "nextcloud",
      "datasourceTemplate": "docker",
      "registryUrlTemplate": "https://index.docker.io"
    }
  ]
}
